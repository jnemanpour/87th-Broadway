{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static HTML Server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url;let fp=p.join('.',decodeURIComponent(u));f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{const ext=p.extname(fp);const types={'.html':'text/html','.css':'text/css','.js':'application/javascript','.pdf':'application/pdf','.json':'application/json','.png':'image/png','.jpg':'image/jpeg'};r.writeHead(200,{'Content-Type':types[ext]||'application/octet-stream'});r.end(d)}})}).listen(8081,()=>console.log('Listening on 8081'))"],
      "port": 8081
    }
  ]
}
